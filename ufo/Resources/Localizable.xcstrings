    "watch.auth.code.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Generate a one-time code or QR on the watch, then approve sign-in in Devices on iPhone, iPad, or Mac."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wygeneruj jednorazowy kod lub QR na zegarku, a potem zatwierdź logowanie w sekcji Urządzenia na iPhonie, iPadzie albo Macu."
          }
        }
      }
    },
    "watch.auth.code.error.backendUnavailable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
