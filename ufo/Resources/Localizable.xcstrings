    "%@ , %@" : {
      "comment" : "A label displaying the latitude and longitude of a location.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ , %2$@"
          }
        }
      }
    },
    "%@ · %@" : {
      "comment" : "A list item in the \"Location\" picker that shows the user-visible name of a location, followed by a short-formatted timestamp indicating when the location was recorded.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ · %2$@"
          }
        }
      }
    },
    "%@ / %@" : {
      "comment" : "A text showing the current amount spent and the target amount for a budget goal.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ / %2$@"
          }
        }
      }
    },
    "%@ %@" : {
      "comment" : "A note indicating that a message has been sent to multiple recipients. The recipient names are joined with a comma and a conjunction like \"and\" or \"etc.\" The argument is the string “messages.view.toPrefix”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$@"
          }
        }
      }
    },
    "%@ • %@" : {
      "comment" : "A subheading that shows the platform and authentication method of a device.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ • %2$@"
          }
        }
      }
    },
    "%@: %lld" : {
      "comment" : "A stepper that allows the user to select a difficulty level for a mission. The label inside the stepper is dynamically generated based on the current value of the difficulty state variable. The argument is the string “missions.editor.field.difficulty”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@: %2$lld"
          }
        }
      }
    },
    "%lld" : {
      "comment" : "A label showing the number of items in a list. The argument is the number of items in the list.",
      "isCommentAutoGenerated" : true
    },
    "%lld/%lld" : {
      "comment" : "A label showing the number of routines completed and the total number of routines for a given day.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld/%2$lld"
          }
        }
      }
    },
    "+%lld" : {
      "comment" : "A badge that shows the number of additional members that are not shown in the main view.",
